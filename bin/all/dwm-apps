#!/usr/bin/env bash
# Auto-start apps (dwm)

tag() {
    xsetroot -name "fsignal:$1"
    sleep 0.2
}

win_count() {
    xprop -root _NET_CLIENT_LIST 2>/dev/null | grep -o '0x[0-9a-f]*' | wc -l
}

run() {
    local before timeout=${2:-10} waited=0
    before=$(win_count)

    sh -c "$1" >/dev/null 2>&1 &

    while [ "$(win_count)" -le "$before" ]; do
        sleep 0.2

        waited=$((waited + 1))
        [ "$waited" -ge $((timeout * 5)) ] && break
    done
}

bg() {
    sh -c "$1" >/dev/null 2>&1 &
    sleep 0.3
}

term="alacritty -e tmux"

if printf '%s' "$(uname -n)" | grep -q 'tp'; then
    tag 1
    bg "sessionizer connect generic"
    run "$term attach-session -t generic"

    tag 2
    run "qutebrowser"

    tag 3
    run "qutebrowser"
else
    tag 1
    run "chromium --new-window"
    bg "sessionizer connect generic"
    run "$term attach-session -t generic"

    tag 2
    run "chromium --new-window https://meteofor.lt/weather-alytus-4152/month"
    run "chromium --app=https://messenger.com"

    tag 3
    run "chromium --new-window https://www.icloud.com/reminders"
    run "firefox --new-window https://www.youtube.com/feed/subscriptions"

    tag 4
    bg "sessionizer connect large"
    run "alacritty -o font.size=50 -e tmux attach-session -t large"

    tag 9
    run "chromium --app=http://gal/$(date +%Y).html"
fi

tag 1
