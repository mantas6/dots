#!/usr/bin/env sh
# Convert code file to html

set -u

for input_file in "$@"; do
    output_file="$input_file.html"

    if [ -f "$output_file" ]; then
        echo "File exists $output_file" >&2
        continue
    fi

    nvim -c "TOhtml | write $output_file | qa" "$input_file"
    add-html-title "$output_file" "$input_file"
done
