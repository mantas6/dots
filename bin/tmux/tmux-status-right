#!/usr/bin/env sh

set -e

changes=false
unpushed=false

if [ "$(git status --short)" != '' ]; then
    changes=true
fi

if git status | grep -q 'Your branch is ahead of'; then
    unpushed=true
fi

status=''
branch=$(git branch --show-current 2>/dev/null)

if $changes; then
    status='#[fg=pink]*#[default]'
fi

if $unpushed; then
    status="$status#[fg=yellow]^#[default]"
fi

printf '%s' "$status$branch"
