# vim: ft=conf

set shell bash
set shellopts '-eu'
set ignorecase true

cmd trash %trash-put $fx

set scrolloff 10
set mouse
set icons
set previewer '~/.config/lf/scope'

map <enter> open
map ` !true
map . set hidden!
map zi zi

cmd on-select &{{
    lf -remote "send $id set statfmt \"$(cd "$PWD" && eza -ld --color=always "$(basename "$f")")\""
}}
