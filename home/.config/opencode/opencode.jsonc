{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": "notify",
    "default_agent": "plan",
    "model": "anthropic/claude-opus-4-6",
    // "enabled_providers": [
    //     "anthropic"
    // ],
    // "mode": {
    //     "build": {
    //         "prompt": "You are Claude Code, Anthropic's official CLI for Claude."
    //     },
    //     "plan": {
    //         "prompt": "You are Claude Code, Anthropic's official CLI for Claude."
    //     }
    // },
    "plugin": [
        // "opencode-anthropic-auth@latest"
    ],
    "permission": {
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        },
        "bash": {
            "*": "allow",
            "git push*": "deny",
            "ssh*": "deny",
            "scp*": "deny",
            "rsync*": "deny",
            "gpg*": "deny",
            "brew*": "deny",
        },
        "external_diretory": {
            "*": "deny",
            "~/Repos/*": "allow",
            "~/Downloads/*": "ask",
        },
    },
    "mcp": {
        "sentry": {
            "enabled": false,
            "type": "remote",
            "url": "https://mcp.sentry.dev/mcp",
            "oauth": {}
        },
        "jira": {
            "enabled": false,
            "type": "remote",
            "url": "https://mcp.atlassian.com/v1/mcp",
            "oauth": {}
        },
        "playwright": {
            "enabled": false,
            "type": "local",
            "command": [
                "npx",
                "@playwright/mcp@latest",
                "--headless",
            ],
        },
    },
}
