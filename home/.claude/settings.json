{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Write(*)",
      "Read(~/Repos/**)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "model": "opus",
  "promptSuggestionEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "jq -r '\"Context: \\(.context_window.used_percentage // 0)% used\"'"
  }
}
